    "evLabels": {
      "problem": "Problem",
      "decision": "Decision",
      "outcome": "Outcome"
    },
    "evidence": [
      {
        "ix": "01",
        "title": "From laggy updates to real time",
        "problem": "Features that needed continuous updates ran on polling - repeated round-trips to the server, with a delay users felt.",
        "decision": "I proposed moving to a WebSocket architecture and was involved on both the client and the server.",
        "outcome": "A genuine real-time experience instead of repeated polling.",
        "tag": "Initiative · architectural decision"
      },
      {
        "ix": "02",
        "title": "A new channel, born from a real need",
        "problem": "Users were missing a group communication channel inside the product workflow.",
        "decision": "I led a chat system end-to-end, including real-time behavior.",
        "outcome": "A meaningful feature that went into daily use inside the existing product.",
        "tag": "Spotting a need · end-to-end build"
      },
      {
        "ix": "03",
        "title": "An interface you don't have to learn",
        "problem": "A brand-new interface creates a learning curve and confuses users.",
        "decision": "Instead of inventing a new UX, I adopted familiar patterns from messaging apps everyone already knows.",
        "outcome": "Users understood the interface intuitively, almost without explanation.",
        "tag": "Product thinking"
      },
      {
        "ix": "04",
        "title": "Keeping large data usable",
        "problem": "Screens with long lists got heavy and hurt the smoothness of the experience.",
        "decision": "I implemented virtualization that renders only what's actually on screen.",
        "outcome": "Smooth scrolling even on lists with very large amounts of data.",
        "tag": "Performance as UX"
      },
      {
        "ix": "05",
        "title": "Cutting the wait on heavy screens",
        "problem": "Screens loaded requests one after another for no reason - and the user waited for nothing.",
        "decision": "I found where loading could happen in parallel and ran the requests together.",
        "outcome": "Shorter load times and a noticeably faster-feeling product.",
        "tag": "Optimization"
      },
      {
        "ix": "06",
        "title": "Making sure users always know what changed",
        "problem": "Users didn't see updated content after images changed, and didn't know what changed between versions.",
        "decision": "A mechanism that forces stale content to refresh, and a clear way to communicate every version change.",
        "outcome": "Users see up-to-date content and know what's new.",
        "tag": "Ownership beyond the code"
      }
    ],
    "pattern": "One pattern repeats across all of these: you don't start from technology - you start from a problem."
  },
